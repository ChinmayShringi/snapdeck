{
  "name": "snapdeck-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Snapdeck: modern section-snap scroll library. Clean-room independent implementation. MIT.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" build",
    "test": "pnpm -r --filter=\"./packages/*\" test",
    "test:run": "pnpm -r --filter=\"./packages/*\" test:run",
    "typecheck": "pnpm -r --filter=\"./packages/*\" typecheck",
    "lint": "pnpm -r --filter=\"./packages/*\" lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6"
  }
}
