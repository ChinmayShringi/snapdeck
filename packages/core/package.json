{
  "name": "@snapdeck/core",
  "version": "0.1.3",
  "description": "Snapdeck core: framework-agnostic section-snap scroll engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/*.css",
    "./src/**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/snapdeck.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fullpage",
    "scroll",
    "section",
    "snap",
    "slider",
    "typescript",
    "fullpage-alternative",
    "fullpagejs",
    "one-page-scroll",
    "scroll-snap",
    "swiper",
    "embla"
  ],
  "author": "Chinmay Shringi",
  "homepage": "https://chinmayshringi.github.io/snapdeck/",
  "bugs": {
    "url": "https://github.com/ChinmayShringi/snapdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChinmayShringi/snapdeck.git",
    "directory": "packages/core"
  }
}
