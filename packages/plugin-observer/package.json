{
  "name": "@snapdeck/plugin-observer",
  "version": "0.1.3",
  "description": "Snapdeck plugin: narrow MutationObserver-based auto-refresh when sections are added or removed.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@snapdeck/core": "workspace:*"
  },
  "devDependencies": {
    "@snapdeck/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "snapdeck",
    "plugin",
    "mutation-observer",
    "reactive"
  ],
  "author": "Chinmay Shringi",
  "homepage": "https://chinmayshringi.github.io/snapdeck/",
  "bugs": {
    "url": "https://github.com/ChinmayShringi/snapdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChinmayShringi/snapdeck.git",
    "directory": "packages/plugin-observer"
  }
}
