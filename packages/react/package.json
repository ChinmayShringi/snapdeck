{
  "name": "@snapdeck/react",
  "version": "0.1.1",
  "description": "React bindings for Snapdeck: hooks and provider for the section-snap scroll engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@snapdeck/core": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@snapdeck/core": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "fullpage",
    "scroll",
    "section",
    "snap",
    "hooks",
    "nextjs"
  ],
  "author": "Chinmay Shringi",
  "homepage": "https://chinmayshringi.github.io/snapdeck/",
  "bugs": {
    "url": "https://github.com/ChinmayShringi/snapdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChinmayShringi/snapdeck.git",
    "directory": "packages/react"
  }
}
