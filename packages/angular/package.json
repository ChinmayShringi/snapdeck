{
  "name": "@snapdeck/angular",
  "version": "0.1.3",
  "description": "Angular bindings for Snapdeck: standalone directive for the section-snap scroll engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": "^18.0.0 || ^19.0.0 || ^20.0.0",
    "@angular/core": "^18.0.0 || ^19.0.0 || ^20.0.0",
    "@snapdeck/core": "workspace:*",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@snapdeck/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "zone.js": "^0.14.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "fullpage",
    "scroll",
    "section",
    "snap",
    "standalone",
    "directive"
  ],
  "author": "Chinmay Shringi",
  "homepage": "https://chinmayshringi.github.io/snapdeck/",
  "bugs": {
    "url": "https://github.com/ChinmayShringi/snapdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChinmayShringi/snapdeck.git",
    "directory": "packages/angular"
  }
}
