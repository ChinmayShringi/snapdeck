{
  "name": "@snapdeck/plugin-progress-bar",
  "version": "0.0.0",
  "description": "Snapdeck plugin: top/bottom reading progress bar driven by section index.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/*.css",
    "./src/**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@snapdeck/core": "workspace:*"
  },
  "devDependencies": {
    "@snapdeck/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "happy-dom": "^15.11.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "snapdeck",
    "plugin",
    "progress-bar",
    "fullpage"
  ]
}
